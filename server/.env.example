# Copy to server/.env and fill in real values. Never commit secrets.

AWS_ACCESS_KEY_ID=
AWS_REGION=us-east-1
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:4000

# Production (Render) — example values:
# CORS_ORIGIN=https://agentos-blue.vercel.app
# FRONTEND_URL=https://agentos-blue.vercel.app
# PUBLIC_API_URL=https://agentos-sc05.onrender.com

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=

# From Supabase → Connect (copy hostname exactly; may be aws-1 not aws-0). URL-encode password special chars.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-us-west-1.pooler.supabase.com:6543/postgres?sslmode=require"
DIRECT_DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-us-west-1.pooler.supabase.com:5432/postgres?sslmode=require"


GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_PRIVATE_KEY=""

LLM_PROVIDER=openai
OPENAI_API_KEY=

LOG_LEVEL=info
NODE_ENV=development
PORT=4000

# Google OAuth (Sign in with Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Defaults to {PUBLIC_API_URL}/api/auth/google/callback
# GOOGLE_OAUTH_REDIRECT_URI=
# GOOGLE_OAUTH_STATE_SECRET=

# Optional webhook to deliver password reset links (email service, Slack, etc.)
# PASSWORD_RESET_WEBHOOK_URL=

# Atlassian OAuth 3LO (Jira Cloud) — preferred connect method
# Atlassian OAuth (Jira Cloud) — also enable matching API scopes in Developer Console
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
# After changing OAuth scopes in code, users must Disconnect + reconnect Jira in the app.
# Defaults to {PUBLIC_API_URL}/api/jira/oauth/callback
# ATLASSIAN_OAUTH_REDIRECT_URI=
# ATLASSIAN_OAUTH_STATE_SECRET=

# Legacy Jira API token (Basic auth fallback)
# JIRA_BASE_URL=https://your-domain.atlassian.net
# JIRA_EMAIL=
# JIRA_API_TOKEN=

# GitNexus knowledge graph (vendored under server/vendor — PolyForm NC; see COMMERCIAL.md)
# Defaults to enabled. Set to 0 to skip graph analyze after index.
# CODEBASE_GITNEXUS_GRAPH=1
# CODEBASE_GITNEXUS_NATIVE=0
# CODEBASE_GRAPH_DATA_DIR=./data/graphs

# --- OSS tool adapters (CLI on host — do NOT vendor full upstream repos) ---
# Render: build runs scripts/install-oss-tools.sh; need ≥1GB RAM (2GB+ recommended).
# Probe: GET /api/integrations/oss-status (auth) or GET /healthz → ossTools
#
# Production: missing CLIs become failed artifacts (not quiet skip).
# Defaults to on when NODE_ENV=production. Force with 1 / off with 0.
# OSS_TOOLS_REQUIRED=1
#
# QA_SEMGREP=0
# Semgrep: pip install semgrep
# QA_COVER_AGENT=0
# Cover-Agent: pip install cover-agent
# QA_HYPOTHESIS=0
# Hypothesis: pip install pytest hypothesis
# QA_LOCUST=0 / CANARY_LOCUST=0
# Locust: pip install locust (default: server/vendor/locust/locustfile.py)
# QA_ZAP=0 / CANARY_ZAP=0
# ZAP: zap-baseline.py or docker pull ghcr.io/zaproxy/zaproxy:stable
# CANARY_LOCUST_CWD=/path/to/dir/with/locustfile.py
# QA_PLAYWRIGHT_BASE_URL=https://your-staging.example
# QA_OSS_ADAPTERS=0          # disable mandatory QA OSS suite
# CANARY_OSS_ADAPTERS=0      # disable mandatory Canary OSS suite
# TOOL_ARTIFACTS_DATA_DIR=./data/tool-artifacts
